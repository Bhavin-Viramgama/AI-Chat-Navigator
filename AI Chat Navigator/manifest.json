{
  "manifest_version": 3,
  "name": "AI Chat Navigator",
  "version": "2.0",
  "description": "Notion-like sidebar navigation for Gemini and ChatGPT.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}